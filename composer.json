{
    "name": "silverday/md2html-php",
    "description": "A secure, self-contained PHP library that converts Markdown files to beautiful, responsive HTML pages with light/dark themes and syntax highlighting.",
    "type": "library",
    "license": "MIT",
    "keywords": ["markdown", "html", "converter", "syntax-highlight", "dark-theme"],
    "authors": [
        {
            "name": "Klaus-E. Klingner",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "classmap": ["src/"]
    },
    "autoload-dev": {
        "classmap": ["tests/"]
    },
    "scripts": {
        "test": "vendor/bin/phpunit tests"
    },
    "config": {
        "optimize-autoloader": true
    },
    "minimum-stability": "stable"
}
